{
  "name": "@crm/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsdown src/index.ts --format esm --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.26.4",
    "@crm/shared": "workspace:*",
    "@hono/node-server": "^1.19.9",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "hono": "^4.12.5",
    "jose": "^6.1.3",
    "kysely": "^0.28.11",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsdown": "^0.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  }
}
